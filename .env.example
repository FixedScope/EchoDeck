# At least one TTS provider is required
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICES=Sam:voice_id_1,Rachel:voice_id_2

# Optional — enables 30 Gemini TTS voices (can be used instead of or alongside ElevenLabs)
GEMINI_API_KEY=

MCP_AUTH_KEY=your_secret_auth_key_here

# Optional
TEST_MODE=false
BASE_URL=https://your-app.railway.app
DATA_DIR=/data
SLIDE_RENDERER=officeOnline
DEFAULT_RESOLUTION=1920x1080
DEFAULT_TRANSITION=none
SLIDE_PADDING_MS=500
MAX_CONCURRENT_TTS=3
JOB_RETENTION_HOURS=24
LIBREOFFICE_PATH=
