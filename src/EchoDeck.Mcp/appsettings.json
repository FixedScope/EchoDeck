{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EchoDeck": {
    "DataDir": "./data",
    "SlideRenderer": "mock",
    "DefaultResolution": "1920x1080",
    "DefaultTransition": "none",
    "SlidePaddingMs": 500,
    "MaxConcurrentTts": 3,
    "JobRetentionHours": 24,
    "TestMode": false
  }
}
